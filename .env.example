# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/chase_the_pulls?schema=public"

# NextAuth (AUTH_URL must match the URL you use in the browser — this app defaults to port 3001)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3001"

# Admin account (used by scripts/ensure-admin.ts and optional auto-promotion on login)
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="change-me-to-a-strong-password"

# OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Cloudinary (server-side upload — restart `npm run dev` after editing)
# Dashboard → API Keys: cloud name, API key, API secret (not the OAuth client id)
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
